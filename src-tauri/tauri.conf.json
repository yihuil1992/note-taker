{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Note Taker",
  "version": "0.2.3",
  "identifier": "com.yihui.notetaker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Note Taker",
        "width": 1760,
        "height": 1040,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyMEMyNzk3QTJFRjhFQjcKUldTM2p1K2lseWNNOG5zUnEwRTBENUN3RVZlZjNBOXZld2JuWFBJVXpNMU9JVGQ5eGVzd0w3eFIK",
      "endpoints": [
        "https://github.com/yihuil1992/note-taker/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
